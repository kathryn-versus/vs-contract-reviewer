rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users can read/write their own doc; admins can read all
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth.uid == uid;
    }

    // Clients: anyone signed in can read; only admins can write
    match /clients/{clientId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();

      match /executedAgreements/{agreementId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
    }

    // Explicit collection-group rule for executedAgreements — belt-and-
    // suspenders alongside the nested match above, so a collectionGroup()
    // query (used by the Library's contracts tracker and client list to
    // read executed agreements across every client at once) is unambiguously
    // covered under Firestore's rules resolution, not just direct per-client
    // subcollection access.
    match /{path=**}/executedAgreements/{agreementId} {
      allow read: if isSignedIn();
    }

    // Contracts: signed-in users can create; only submitter or admin can read
    match /contracts/{contractId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() &&
        (resource.data.submittedBy.uid == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();

      match /versions/{versionId} {
        allow read: if isSignedIn() &&
          (get(/databases/$(database)/documents/contracts/$(contractId))
            .data.submittedBy.uid == request.auth.uid || isAdmin());
        allow create: if isSignedIn();
        allow update, delete: if isAdmin();

        match /issueThreads/{threadId} {
          allow read, write: if isSignedIn() &&
            (get(/databases/$(database)/documents/contracts/$(contractId))
              .data.submittedBy.uid == request.auth.uid || isAdmin());
        }
      }
    }
  }
}
